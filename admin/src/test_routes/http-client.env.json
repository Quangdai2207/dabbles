{
  "dev": {
    "domain": "http://localhost:3366",
    "settings": {
      "timeout": 10000
    },
    "version": {
      "v1": "/api/v1",
      "v2": "/api/v2"
    },
    "auth": {
      "bearer_token": "",
      "cookie": ""
    },
    "roles": {
      "super_admin": "SUPERADMIN",
      "admin": "ADMIN",
      "doctor": "",
      "patient": ""
    },
    "params": {
      "page": 1,
      "size": 10,
      "keyword": "test"
    },
    "sample": {
      "id": 1,
      "email": "example@gmail.com"
    },
    "permission": {
      "auth": {
        "prefix": "/api/auth",
        "uri": {
          "login": "/login",
          "register": "/register",
          "forget-password": "/forget-password",
          "change-password": "/change-password"
        },
        "header": {
          "json": "application/json",
          "form_data": "multipart/form-data",
          "cookie": "application/x-www-form-urlencoded"
        }
      },
      "n_admin": {
        "prefix": "/api/admin",
        "uri": {
          "get_all": "/",
          "get_by_id": "/{id}",
          "search_by_keyword": "/search",
          "search_by_email": "/email",
          "details": "/details/{id}"
        },
        "headers": {
          "json": "application/json",
          "form_data": "multipart/form-data",
          "cookie": "application/x-www-form-urlencoded"
        }
      },
      "s_admin": {
        "prefix": "/api/super-admin",
        "uri": {
          "get_all": "/",
          "get_by_id": "/{id}",
          "search_by_keyword": "/search",
          "search_by_email": "/email",
          "details": "/details/{id}"
        },
        "headers": {
          "json": "application/json",
          "form_data": "multipart/form-data",
          "cookie": "application/x-www-form-urlencoded"
        }
      }
    }
  }
}
