FROM maven AS build
WORKDIR /build
COPY ./pom.xml .
RUN mvn -B dependency:go-offline
COPY . .
RUN mvn package
CMD ls -n ./ | grep "*.jar"

## Runtime
FROM eclipse-temurin:17-jre
WORKDIR /app
COPY --from=build /build/target/*.jar .

ENV JAVA_OPTS="-XX:+UseContainerSupport -XX:MaxRAMPercentage=75"
EXPOSE 9999